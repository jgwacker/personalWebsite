---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PostCard from '@components/PostCard.astro';
const posts = (await getCollection('blog', (p) => !p.data.draft)).sort((a,b)=>+new Date(b.data.pubDate)-+new Date(a.data.pubDate));

// Compute tag frequencies
const counts = new Map<string, number>();
for (const p of posts) for (const t of p.data.tags || []) counts.set(t, (counts.get(t)||0)+1);
---
<BaseLayout title="Blog">
  <div class="flex flex-wrap gap-2 mb-6">
    {[...counts.entries()].sort((a,b)=>b[1]-a[1]).map(([t,n])=> (
      <a class="rounded-full border border-base-border px-3 py-1 text-xs hover:bg-base-accent/5" href={`/blog/tags/${t}/`}>{t} ({n})</a>
    ))}
  </div>
  <section>
    {posts.map((p) => <PostCard entry={p} />)}
  </section>
</BaseLayout>