---
import IndexLayout from '@layouts/IndexLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog', (p) => !p.data.draft)).sort((a,b)=>+new Date(b.data.pubDate)-+new Date(a.data.pubDate)).slice(0,4);
const allResearch = await getCollection('research', (p) => !p.data.draft);
---
<IndexLayout>
  <section class="grid gap-10">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight">Jay Wacker</h1>
      <p class="mt-2 max-w-2xl">I live in the Bay Area with my wife Mira and daughter Zoe. I've spent my career moving between deep technical problems and the real world. As a theoretical physicist at SLAC and Stanford, I proposed new paradigms for dark matter, helped redesign how the LHC searches for new particles, and published 64 papers with ~10,000 citations. At Quora, I built the systems that organized the world's knowledge on a top-30 website. At Apple, I lead the ML team behind Siri's natural language understanding, shipping across 6 operating systems to billions of users.</p>
      <p class="mt-2 max-w-2xl">I write about things I'm curious about: wealth tax design from first principles, what Bronze Age DNA reveals about Greek mythology, and how to develop engineers who think for themselves. Outside of work, I cook, take photographs, travel actively (40+ countries and counting), and read too many books about ancient civilizations.</p>
    </div>

    <div>
      <h2 class="text-2xl font-semibold tracking-tight">Latest writing</h2>
      <ul class="mt-4 grid gap-4">
        {posts.map((p) => (
          <li><a class="hover:underline" href={`/blog/${p.slug}/`}>{p.data.title}</a> <span class="text-base-mute">— {new Date(p.data.pubDate).toLocaleDateString()}</span></li>
        ))}
      </ul>
      <a href="/blog/" class="mt-3 inline-block">All posts →</a>
    </div>

    <div>
      <h2 class="text-2xl font-semibold tracking-tight">Selected research</h2>
      <ul id="research-list" class="mt-4 grid gap-3">
        {allResearch.map((r) => (
          <li class="research-item" style="display:none;">
            <a class="hover:underline" href={`/research/${r.slug}/`}>{r.data.title}</a>
            {r.data.venue && <span class="text-base-mute"> — {r.data.venue}</span>}
          </li>
        ))}
      </ul>
      <a href="/research/" class="mt-3 inline-block">All research →</a>
      <script>
        const items = Array.from(document.querySelectorAll('.research-item'));
        for (let i = items.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [items[i], items[j]] = [items[j], items[i]];
        }
        items.slice(0, 4).forEach(el => el.style.display = '');
      </script>
    </div>
  </section>
</IndexLayout>