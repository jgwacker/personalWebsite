---
import BaseLayout from '@layouts/BaseLayout.astro';
import { photos } from '@data/photos';
---
<BaseLayout title="Photography">
  <section class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
    {photos.map((p)=> (
      <div class="group">
        <img src={p.src} alt={p.title || ''} class="w-full aspect-[3/2] object-cover rounded-xl border border-base-border shadow-sm" loading="lazy" />
        {(p.title || p.location || p.date) && (
          <div class="mt-2 text-sm text-base-mute">{p.title} {p.location && `· ${p.location}`} {p.date && `· ${p.date}`}</div>
        )}
      </div>
    ))}
  </section>
</BaseLayout>