---
import TagPill from './TagPill.astro';
const { entry } = Astro.props; // entry: CollectionEntry<'blog'>
const { data, slug } = entry;
---
<article class="group border-b border-base-border py-6">
  <h3 class="text-xl font-semibold leading-tight tracking-tight">
    <a href={`/blog/${slug}/`} class="hover:underline">{data.title}</a>
  </h3>
  <p class="mt-2 text-base-mute">{new Date(data.pubDate).toLocaleDateString()}</p>
  {data.description && <p class="mt-2">{data.description}</p>}
  {data.tags?.length && (
    <div class="mt-3 flex flex-wrap gap-2">
      {data.tags.map((t) => <TagPill tag={t} />)}
    </div>
  )}
</article>