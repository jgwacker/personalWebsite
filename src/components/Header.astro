---
const nav = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/research/', label: 'Research' },
  { href: '/photography/', label: 'Photography' },
  { href: '/resume', label: 'Résumé' }
];
---
<header class="border-b border-base-border bg-white/70 backdrop-blur supports-[backdrop-filter]:bg-white/60 sticky top-0 z-50">
  <div class="container flex items-center justify-between h-14">
    <a href="/" class="text-base-text font-semibold tracking-tight">JW</a>
    <nav class="flex gap-5 text-sm">
      {nav.map((i) => <a class="hover:opacity-80" href={i.href}>{i.label}</a>)}
    </nav>
  </div>
</header>