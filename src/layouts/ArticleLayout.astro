---
import BaseLayout from './BaseLayout.astro';
import Prose from '@components/Prose.astro';
const { frontmatter } = Astro.props;

// Route tag links to the correct collection.
const path = Astro.url.pathname;
const tagBase = path.startsWith('/research/') ? '/research/tags' : '/blog/tags';
---
<BaseLayout title={frontmatter.title}>
  <article class="prose">
    <header class="mb-8">
      <h1>{frontmatter.title}</h1>
      {frontmatter.pubDate && (
        <p class="text-base-mute">{new Date(frontmatter.pubDate).toLocaleDateString()}</p>
      )}
      {frontmatter.tags?.length && (
        <div class="mt-2 flex flex-wrap gap-2">
          {frontmatter.tags.map((t) => (
            <a href={`${tagBase}/${t}/`} class="text-sm">#{t}</a>
          ))}
        </div>
      )}
    </header>
    <slot />
  </article>
</BaseLayout>
